# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenAI
OPENAI_API_KEY=sk-your_openai_key_here

# Payments: 한국 사용 시 Stripe 미사용. Pro는 인앱 결제(IAP) 예정.
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=

# App
EXPO_PUBLIC_APP_ENV=development

# API base (optional).
# - Development on device/emulator: PC's LAN IP so the app can reach Metro/API.
#   Example: EXPO_PUBLIC_API_URL=http://192.168.0.5:8081
# - Production (EAS native build): your hosted API URL (Schedule/Inbox/Notes/Review AI endpoints).
#   Example: EXPO_PUBLIC_API_URL=https://api.yourdomain.com
# EXPO_PUBLIC_API_URL=
